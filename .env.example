# --- LLM provider selection ---
# One of: openrouter (default) | openai | anthropic
LLM_PROVIDER=openrouter
# Uniform across providers (fail fast instead of hanging; bounded retries)
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2

# --- OpenRouter (used when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Aurora - WHO Neonatal Mortality Analyst

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-5

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Safeguard (always via OpenRouter, independent of LLM_PROVIDER) ---
SAFEGUARD_MODEL=openai/gpt-oss-safeguard-20b
SAFEGUARD_TIMEOUT_MS=5000

# --- PostgreSQL: privileged role (used ONLY by data/seed.ts) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=aurora
PGUSER=aurora_admin
PGPASSWORD=postgres

# --- PostgreSQL: read-only role (used by the app at request time — Principle IV) ---
PG_READONLY_USER=aurora_readonly
PG_READONLY_PASSWORD=readonly

# --- Conversation DB (aurora_app role — write access to conversation tables only) ---
PGAPP_USER=aurora_app
PGAPP_PASSWORD=apppass

# --- App ---
PORT=4000
# Comma-separated list of allowed origins for CORS (the web UI container). Use * for dev.
CORS_ORIGIN=*
